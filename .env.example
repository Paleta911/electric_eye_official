# Copia este archivo como .env y reemplaza todos los valores CHANGE_ME.
# Nunca confirmes el archivo .env en Git.

# Base de datos compartida por Python y Node.js
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=video_database

# Seguridad del backend: usa valores aleatorios, largos y distintos entre sí
JWT_SECRET=CHANGE_ME_USE_AT_LEAST_32_RANDOM_BYTES
ADMIN_ACCESS_KEY=CHANGE_ME_USE_A_DIFFERENT_RANDOM_VALUE

# Configuración de la IA
API_URL=http://localhost:3000/api/rostros
REFERENCE_DIRECTORY=./fotos
PICKLE_FILE=./reference_encodings.pkl
MODEL_PATH=./entrenamiento.pt

# Solo es necesario cuando se selecciona una cámara IP
CAMERA_IP_URL=rtsp://usuario:contrasena@host:puerto/ruta
